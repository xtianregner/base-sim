# Entorno virtual de Python
.venv/
venv/
env/
.env/

# Archivos de Python compilados
__pycache__/
*.py[cod]
*$py.class
*.so

# Base de datos SQLite (desarrollo)
*.sqlite3
db.sqlite3

# Variables de entorno (contiene secrets)
.env
.env.local
.env.*.local

# Archivos de IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# Documentación y contexto (no necesarios en producción)
README.md
CONTEXTO_PROYECTO.md
docs/

# Tests
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# Archivos de distribución
dist/
build/
*.egg-info/
*.egg

# Archivos de sistema
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Archivos temporales
tmp/
temp/
*.tmp

# Node (si agregas frontend)
node_modules/
npm-debug.log

# Archivos de caché
.cache/
*.cache

# Archivos de migración (opcional - descomenta si quieres excluirlos)
# */migrations/*.py
# !*/migrations/__init__.py

# Static files collected (se generan en producción)
staticfiles/
static_collected/
